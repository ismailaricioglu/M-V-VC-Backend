<!-- Bu sayfanın modeli olarak bir ürün kullanılıyor -->
@model Product

<div class="row">
    <div class="col-md-12">
        <div class="text-center">
            <!-- Ürün adını gösteren başlık -->
            <h6 class="display-6">
                @Model.ProductName
            </h6>

            <img class="img-fluid shadow rounded-3 p-5 my-3" src="@Model?.ImageUrl" alt="@Model.ProductName" />

            <!-- Ürün fiyatını gösteren paragraf -->
            <p class="lead text-danger">@Model.Price.ToString("c")</p>
        </div>
    </div>
</div>

<div class="text-center">
    <div class="btn-group">
        <!-- Ana sayfaya yönlendiren buton -->
        <a class="btn btn-outline-primary" asp-controller="Home" asp-action="Index">
            <i class="fa-solid fa-house"></i>
            Home
        </a>
        <!-- Sepet sayfaya yönlendiren buton, istek adresinide gönderir -->
        <form id="@Model.ProductId" asp-page="/cart" method="post">
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
            <button type="submit" class="btn btn-outline-secondary rounded-0">
                <i class="fa fa-cart-plus"></i>
                Add To Cart
            </button>
        </form>
        <!-- Ürünler sayfasına yönlendiren buton -->
        <a class="btn btn-outline-secondary" asp-controller="Product" asp-action="Index">
            <i class="fa-solid fa-list"></i>
            Products
        </a>
    </div>
</div>

<!-- Sadece Get sayfası için başlık bölümü -->
@section Header {
    <div>
        Header for only Get
    </div>
}