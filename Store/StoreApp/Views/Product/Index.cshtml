<!-- Bu sayfanın modeli olarak bir ürün listesi kullanılıyor -->
@model ProductListViewModel

<div class="row">
    <div class="col-md-3">
        @await Component.InvokeAsync("CategoriesMenu")
        @await Component.InvokeAsync("ProductFilterMenu")
        <div products=""></div>

    </div>
    <div class="col-md-9">
        <!-- Bootstrap sınıfları kullanılarak bir satır oluşturuluyor -->
        <div class="row my-3">
            <!-- Modeldeki her bir ürün için döngü başlatılıyor -->
            @foreach (Product prd in Model.Products)
            {
                <!-- Her bir ürün için "_ProductCard" partial view'i çağrılıyor ve model olarak ürün gönderiliyor -->
                <partial name="_ProductCard" model="@prd" />
            }
        </div>
        <div class="text-center">
            <div page-model="@Model?.Pagination" page-action="Index" page-classes-enabled="true" page-class="btn"
                 page-class-normal="btn-outline-dark" page-class-selected="btn-secondary" class="btn-group">
            </div>
        </div>
    </div>
</div>

@section Footer {
    <!-- Bu bölüm, sayfanın footer (altbilgi) kısmını tanımlar -->
    <div>
        <!-- Footer kısmında gösterilecek metin -->
        Only for Index footer
    </div>
}
